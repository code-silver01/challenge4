# ─────────────────────────────────────────────────────────────────────
# Setu — Environment Variables (.env.example)
# Copy to .env and fill in real values before running.
# ─────────────────────────────────────────────────────────────────────

# Google Gemini API key (required for LLM features)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Firestore (optional — set USE_FIRESTORE=true to enable)
FIRESTORE_PROJECT_ID=
USE_FIRESTORE=false

# Server settings
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_RPM=30
ENV=dev
